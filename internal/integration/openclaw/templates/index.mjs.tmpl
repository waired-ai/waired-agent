// waired OpenClaw integration — registers an independent "waired" provider
// via an OpenClaw plugin, so no `models.providers` edit to openclaw.json is
// needed.
//
// GENERATED by waired (`waired link openclaw`). Do not edit: it is rewritten
// on every link and deleted on unlink. The provider points at waired's
// no-token loopback data-plane gateway. `resolveDynamicModel` maps the
// reference `waired/{default,coding,small}` to a runtime model whose `id` is the
// wire string the gateway expects (its catalog aliases: waired/default -> coding
// 7B, waired/small -> 3B). `resolveSyntheticAuth` supplies a non-secret local
// marker so no API key or environment variable is ever required — the same
// pattern OpenClaw's own local Ollama / LM Studio providers use.
const BASE_URL = {{ .BaseURLLiteral }};
const SYNTHETIC_KEY = "waired-local";
const MODEL_KEYS = ["default", "coding", "small"];
const COST = { input: 0, output: 0, cacheRead: 0, cacheWrite: 0 };

function wairedModel(key) {
  return {
    id: "waired/" + key,
    name: "Waired " + key.charAt(0).toUpperCase() + key.slice(1),
    provider: "waired",
    api: "openai-completions",
    baseUrl: BASE_URL,
    reasoning: false,
    input: ["text"],
    cost: COST,
    contextWindow: 32768,
    maxTokens: 8192,
    compat: { supportsTools: true, supportsUsageInStreaming: true },
  };
}

export default {
  id: "waired",
  name: "Waired",
  description: "Waired local inference provider",
  register(api) {
    api.registerProvider({
      id: "waired",
      label: "Waired",
      // Non-secret synthetic credential: the data-plane gateway is no-token,
      // but OpenClaw requires *some* resolvable key before it will dispatch.
      resolveSyntheticAuth: () => ({
        apiKey: SYNTHETIC_KEY,
        source: "waired plugin (synthetic local key)",
        mode: "api-key",
      }),
      shouldDeferSyntheticProfileAuth: ({ resolvedApiKey }) =>
        (resolvedApiKey || "").trim() === SYNTHETIC_KEY,
      // Resolve waired/{auto,coding,small} without a models.providers config
      // entry. The returned model's `id` becomes the on-wire model string.
      resolveDynamicModel: (ctx) => {
        const key = String((ctx && ctx.modelId) || "").replace(/^waired\//, "");
        return MODEL_KEYS.includes(key) ? wairedModel(key) : null;
      },
    });
  },
};
