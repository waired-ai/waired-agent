// waired OpenCode integration — registers the "waired" provider via the
// OpenCode plugin `config` hook, so no opencode.json edit is needed.
//
// GENERATED by waired (`waired link opencode`). Do not edit: it is
// rewritten on every link and deleted on unlink. The provider points at
// waired's no-token loopback data-plane gateway; the model `id` values are
// the gateway's catalog aliases (waired/default -> coding 7B, waired/small ->
// 3B), while the map keys give a clean `waired/<name>` address in the picker.
export const WairedPlugin = async () => ({
  config: async (config) => {
    config.provider = config.provider || {};
    config.provider.waired = {
      npm: "@ai-sdk/openai-compatible",
      name: "Waired",
      options: { baseURL: {{ .BaseURLLiteral }} },
      models: {
        default: { id: "waired/default", name: "Waired Default" },
        coding:  { id: "waired/coding",  name: "Waired Coding" },
        small:   { id: "waired/small",   name: "Waired Small" },
      },
    };
  },
});
