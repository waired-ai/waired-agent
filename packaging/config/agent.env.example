# /etc/waired/agent.env — environment for the waired-agent systemd unit.
#
# Copy this file to /etc/waired/agent.env and fill in the values for your
# deployment, then enable the daemon:
#
#   sudo cp /etc/waired/agent.env.example /etc/waired/agent.env
#   sudo $EDITOR /etc/waired/agent.env
#   sudo systemctl enable --now waired-agent
#
# Before the daemon can run you also need to enroll this device against
# your Control Plane. Either run `waired init` from a privileged shell or
# right-click the waired-tray icon and pick "Log in...".

# Required for `waired init` (the daemon reads identity from state-dir,
# so this is consumed at enrollment time, not at every boot).
# WAIRED_CONTROL_URL=https://control.example.com

# Override the on-disk state location if you don't want /var/lib/waired.
# WAIRED_STATE_DIR=/var/lib/waired

# Override the WireGuard UDP listen port (default 51820).
# WAIRED_LISTEN_PORT=51820
