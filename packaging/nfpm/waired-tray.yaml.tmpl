name: waired-tray
arch: ${ARCH}
version: ${PKG_VERSION}
version_schema: none
section: net
priority: optional
maintainer: "Waired Maintainers <maintainers@waired.dev>"
description: |
  System tray icon for Waired. Talks to the local waired-agent
  Management API on 127.0.0.1:9476 and brokers the privileged
  enrollment / logout commands through pkexec / polkit.
vendor: Waired
homepage: https://github.com/waired-ai/waired
license: Apache-2.0

depends:
  - waired (>= ${PKG_VERSION})
  # pkexec is the package that ships /usr/bin/pkexec on Debian bookworm+
  # / Ubuntu 24.04+. The old `policykit-1` is a transitional package
  # there and has been *removed* in Ubuntu 26.04 / Debian trixie, so a
  # bare `policykit-1` dependency makes `apt install waired-tray`
  # unsatisfiable on those releases. The `| policykit-1` alternative
  # keeps older releases (Ubuntu jammy and earlier, Debian bullseye)
  # working, where pkexec is still provided by policykit-1 itself.
  - pkexec | policykit-1

# GNOME has no built-in SNI host, so on GNOME the tray icon only renders with an
# AppIndicator host extension (issue #493). This is Suggests, NOT Recommends, on
# purpose: Recommends is auto-installed by apt and would pull a GNOME extension
# (and its gnome-shell deps) onto KDE / minimal / server installs that don't need
# it. The actual fix is runtime: `waired init` auto-installs+enables this when it
# detects GNOME, and `waired doctor` reports when no SNI host is present. The
# Suggests just advertises it (apt show / GUI front-ends) for manual installs.
suggests:
  - gnome-shell-extension-appindicator

contents:
  - src: bin/linux_${ARCH}/waired-tray
    dst: /usr/bin/waired-tray
    file_info:
      mode: 0755

  - src: build/autostart/waired-tray.desktop
    dst: /etc/xdg/autostart/waired-tray.desktop
    file_info:
      mode: 0644

  # App-grid launcher (issue #492): the autostart entry above is not
  # shown in the GNOME application list, so without this the tray is
  # undiscoverable / unlaunchable from the GUI. Exec is PATH-relative
  # (waired-tray) so it resolves against /usr/bin here and
  # /usr/local/bin for the manual installer.
  - src: build/applications/waired-tray.desktop
    dst: /usr/share/applications/waired-tray.desktop
    file_info:
      mode: 0644

  - src: build/polkit/com.waired.policy
    dst: /usr/share/polkit-1/actions/com.waired.policy
    file_info:
      mode: 0644

scripts:
  postinstall: packaging/debian/waired-tray/postinst
  postremove:  packaging/debian/waired-tray/postrm

deb:
  fields:
    Bugs: https://github.com/waired-ai/waired/issues
